# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# AWS region where SES is enabled and verified identities exist.
AWS_REGION=us-east-1

# Optional: explicit AWS credentials (boto3 also reads ~/.aws/credentials and IAM roles).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# SMTP listener bind address and port.
LISTEN_HOST=127.0.0.1
LISTEN_PORT=1025

# Optional: path to an alternate env file (used by systemd/docker).
# ENV_FILE=/etc/smtp-to-ses/.env

# Optional: logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# --- Email / domain validation ---

# Comma-separated sender domains allowed in MAIL FROM (match your SES verified identities).
# Leave empty to allow any syntactically valid sender.
ALLOWED_SENDER_DOMAINS=example.com

# Comma-separated recipient domains allowed in RCPT TO (empty = allow all).
# ALLOWED_RECIPIENT_DOMAINS=example.com,customer.com

# Verify each address domain has MX or A/AAAA DNS records before accepting.
REQUIRE_MX_RECORD=false

# --- Spam checking ---

# Master switch for spam checks (DNSBL + optional SpamAssassin).
SPAM_CHECK_ENABLED=true

# Block connecting IPs listed on DNS blocklists.
SPAM_DNSBL_ENABLED=true

# Comma-separated DNSBL zones queried against the client IP.
SPAM_DNSBL_ZONES=zen.spamhaus.org,b.barracudacentral.org,bl.spamcop.net

# Optional SpamAssassin spamd address (host:port). Requires spamd running locally.
# SPAMASSASSIN_HOST=127.0.0.1:783

# Reject messages with a SpamAssassin score at or above this value.
SPAM_SCORE_THRESHOLD=5.0

# --- SMTP authentication (optional) ---

# When both are set, clients must authenticate before sending mail.
# Supports PLAIN and LOGIN. Leave empty to disable auth.
# SMTP_AUTH_USERNAME=smtp_user
# SMTP_AUTH_PASSWORD=change-me-to-a-strong-password
